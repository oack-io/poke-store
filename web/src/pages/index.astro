---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <div class="hero">
    <div class="hero-content">
      <h1 class="hero-title">
        <span class="hero-gotta">Gotta Buy</span>
        <span class="hero-em">'Em All!</span>
      </h1>
      <p class="hero-subtitle">
        Welcome to PokéStore — the world's most trusted marketplace for original Generation I Pokémon.
        Browse our curated collection, add your favorites to cart, and check out in seconds.
      </p>
      <div class="hero-actions">
        <a href="/store" class="btn btn-primary btn-lg" data-testid="browse-btn">Browse Pokémon</a>
        <a href="/login" class="btn btn-accent btn-lg" data-testid="login-btn">Sign In</a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-number">25</span>
          <span class="stat-label">Pokémon Available</span>
        </div>
        <div class="stat">
          <span class="stat-number">$1.99</span>
          <span class="stat-label">Starting From</span>
        </div>
        <div class="stat">
          <span class="stat-number">Gen I</span>
          <span class="stat-label">Original Series</span>
        </div>
      </div>
    </div>
    <div class="hero-pokeball"></div>
  </div>

  <section class="features">
    <h2 class="section-title">Why PokéStore?</h2>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">&#x1F50D;</div>
        <h3>Search & Filter</h3>
        <p>Find Pokémon by name or type. Our advanced search makes discovery effortless.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#x1F6D2;</div>
        <h3>Easy Cart</h3>
        <p>Add Pokémon to your cart with one click. Adjust quantities anytime.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#x26A1;</div>
        <h3>Instant Checkout</h3>
        <p>Secure checkout powered by PokéDollars. No Gym Badges required.</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 60px 0;
    position: relative;
    overflow: hidden;
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .hero-title {
    font-family: 'Press Start 2P', cursive;
    font-size: 2.2rem;
    line-height: 1.4;
    margin-bottom: 20px;
  }

  .hero-gotta { color: var(--color-secondary); }
  .hero-em { color: var(--color-primary); display: block; }

  .hero-subtitle {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto 32px;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 48px;
  }

  .hero-stats {
    display: flex;
    gap: 48px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .stat-number {
    font-family: 'Press Start 2P', cursive;
    font-size: 1.3rem;
    color: var(--color-primary);
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .hero-pokeball {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(238, 21, 21, 0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  .features { padding: 40px 0; }

  .section-title {
    font-family: 'Press Start 2P', cursive;
    font-size: 1.1rem;
    text-align: center;
    margin-bottom: 32px;
    color: var(--color-secondary);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }

  .feature-card {
    background: var(--color-card);
    border-radius: var(--radius);
    padding: 32px 24px;
    text-align: center;
    box-shadow: var(--shadow);
  }

  .feature-icon {
    font-size: 2.5rem;
    margin-bottom: 16px;
  }

  .feature-card h3 {
    margin-bottom: 8px;
    font-size: 1.1rem;
  }

  .feature-card p {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  @media (max-width: 640px) {
    .hero-title { font-size: 1.5rem; }
    .hero-stats { gap: 24px; }
  }
</style>
